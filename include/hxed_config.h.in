// compile-time configuration header for hxed
#ifndef HXED_CONFIG_H
#define HXED_CONFIG_H

#define HXED_VERSION_MAJOR @PROJECT_VERSION_MAJOR@
#define HXED_VERSION_MINOR @PROJECT_VERSION_MINOR@
#define HXED_VERSION_PATCH @PROJECT_VERSION_PATCH@
#define HXED_VERSION_STR   "@PROJECT_VERSION@"

#define GLOBAL_CONFIG_DIR "@GLOBAL_CONFIG_DIR@"
#define GLOBAL_DATA_DIR    "@CMAKE_INSTALL_FULL_DATAROOTDIR@/hxed"

#endif